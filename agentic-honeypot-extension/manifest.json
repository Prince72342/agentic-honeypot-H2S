{
  "manifest_version": 3,
  "name": "Agentic Honeypot SOC",
  "version": "1.0",
  "description": "Deploy an AI Honeypot Agent to engage scammers and extract intelligence.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Honeypot Agent"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ]
}
